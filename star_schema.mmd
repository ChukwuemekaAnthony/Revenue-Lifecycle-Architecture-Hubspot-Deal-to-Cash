erDiagram

    dim_date {
        INT date_key PK
        DATE full_date
        INT day_of_week
        VARCHAR day_name
        INT week_of_year
        INT month_number
        VARCHAR month_name
        INT quarter
        INT calendar_year
        INT fiscal_year
        BOOLEAN is_weekday
        BOOLEAN is_month_end
    }

    dim_company {
        INT sk_company PK
        VARCHAR company_id
        VARCHAR company_name
        VARCHAR industry
        VARCHAR region
        VARCHAR client_status
        INT bed_count
        BOOLEAN is_current
    }

    dim_contract {
        INT sk_contract PK
        VARCHAR contract_id
        VARCHAR fk_deal_id
        INT sk_company FK
        VARCHAR contract_status
        DECIMAL contract_value
        DECIMAL contracted_margin
        INT contract_start_date_key FK
        INT contract_end_date_key FK
        BOOLEAN is_current
    }

    dim_asset {
        INT sk_asset PK
        VARCHAR asset_id
        INT sk_facility FK
        INT sk_contract FK
        VARCHAR serial_number
        VARCHAR equipment_type
        VARCHAR manufacturer
        VARCHAR lifecycle_stage
        DECIMAL service_risk_score
        BOOLEAN is_current
    }

    dim_facility {
        INT sk_facility PK
        VARCHAR facility_id
        INT sk_company FK
        VARCHAR facility_name
        VARCHAR facility_type
        VARCHAR city
        VARCHAR state
    }

    dim_vendor {
        INT sk_vendor PK
        VARCHAR vendor_id
        VARCHAR vendor_name
        VARCHAR vendor_type
        VARCHAR region
        BOOLEAN preferred_vendor
    }

    dim_contact {
        INT sk_contact PK
        VARCHAR contact_id
        INT sk_company FK
        VARCHAR full_name
        VARCHAR role_type
        VARCHAR decision_authority
    }

    fact_deal {
        INT sk_deal_event PK
        VARCHAR deal_id
        INT sk_company FK
        INT sk_contact FK
        INT created_date_key FK
        INT closed_won_date_key FK
