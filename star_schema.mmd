        DECIMAL weighted_value
        DECIMAL expected_margin
        DECIMAL stage_probability
        VARCHAR deal_stage
        BOOLEAN is_closed_won
        INT total_sales_cycle_days
    }

    fact_invoice {
        INT sk_invoice PK
        VARCHAR invoice_id
        VARCHAR deal_id
        INT sk_company FK
        INT sk_contract FK
        INT invoice_date_key FK
        INT payment_received_date_key FK
        DECIMAL invoice_amount
        DECIMAL total_amount
        BOOLEAN is_paid
        BOOLEAN is_overdue
        INT days_to_payment
    }

    fact_cost {
        INT sk_cost PK
        VARCHAR cost_id
        VARCHAR deal_id
        INT sk_contract FK
        INT cost_recorded_date_key FK
        DECIMAL labor_cost
        DECIMAL vendor_cost
        DECIMAL equipment_cost
        DECIMAL allocated_overhead
        DECIMAL total_cost
    }

    fact_maintenance {
        INT sk_maintenance PK
        VARCHAR maintenance_event_id
        INT sk_asset FK
        INT sk_vendor FK
        INT sk_facility FK
        INT sk_contract FK
        INT maintenance_date_key FK
        VARCHAR maintenance_type
        DECIMAL downtime_hours
        DECIMAL repair_cost
        BOOLEAN billable_flag
        INT days_since_last_service
    }

